ARG AIRFLOW_VERSION="3.2.1"
ARG PYTHON_VERSION="3.11"
ARG AIRFLOW_IMAGE="apache/airflow:slim-${AIRFLOW_VERSION}-python${PYTHON_VERSION}"

FROM ${AIRFLOW_IMAGE}

USER root

RUN apt-get update -qq && \
    apt-get install -q=2 --yes --no-install-recommends git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER airflow

COPY pyproject.toml uv.lock /opt/airflow/
COPY dags/ /opt/airflow/dags/
COPY tests/ /opt/airflow/tests/

RUN pip install --no-cache-dir uv && \
    mkdir -p /home/airflow/repositories && \
    uv sync --dev

ENV AIRFLOW_HOME=/opt/airflow
ENV PATH="/home/airflow/.local/bin:$PATH"

CMD ["pytest", "tests/", "-v", "--ignore=tests/operators/"]
