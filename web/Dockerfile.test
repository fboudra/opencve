ARG PYTHON_VERSION="3.11"

FROM python:${PYTHON_VERSION}-slim-trixie

RUN apt-get update -qq && \
    apt-get install -q=2 --yes --no-install-recommends git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml uv.lock ./
COPY opencve/ ./opencve/
COPY manage.py ./
COPY cves/ ./cves/
COPY changes/ ./changes/
COPY projects/ ./projects/
COPY organizations/ ./organizations/
COPY users/ ./users/
COPY dashboards/ ./dashboards/
COPY views/ ./views/
COPY onboarding/ ./onboarding/
COPY tests/ ./tests/
COPY static/ ./static/
COPY templates/ ./templates/
COPY cves/templates/ ./cves/templates/
COPY projects/templates/ ./projects/templates/
COPY organizations/templates/ ./organizations/templates/
COPY users/templates/ ./users/templates/
COPY changes/templates/ ./changes/templates/
COPY dashboards/templates/ ./dashboards/templates/
COPY views/templates/ ./views/templates/
COPY onboarding/templates/ ./onboarding/templates/
COPY opencve/conf/settings.py.example opencve/conf/settings.py

RUN uv sync --dev

ENV DJANGO_SETTINGS_MODULE=opencve.conf.settings
ENV PYTHONPATH=/app
ENV PATH="/app/.venv/bin:$PATH"

CMD ["python", "-m", "pytest", "tests/", "-v"]
